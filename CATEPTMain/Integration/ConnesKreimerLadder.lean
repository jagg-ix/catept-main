import Mathlib.Data.Real.Basic
import Mathlib.Data.Nat.Choose.Basic
import Mathlib.Tactic.Ring
import Mathlib.Tactic.Linarith

/-!
# Connes–Kreimer Hopf Algebra of Feynman Graphs — Ladder Sector (T-DD Phase 1)

Phase-1 honest algebraic content of the **Connes–Kreimer Hopf
algebra of Feynman graphs**, restricted to the *ladder* (linear
chain of primitive subgraphs) sector. The ladder sector is the
universal sub-Hopf-algebra generated by a single primitive `x`,
isomorphic to the polynomial Hopf algebra `ℝ[x]` with primitive
coproduct `Δ(x) = x⊗1 + 1⊗x` and `Δ(xⁿ) = (x⊗1 + 1⊗x)ⁿ`.

Concretely, the `(k, n−k)`-component of `Δ(xⁿ)` in the ladder
Hopf algebra is the binomial coefficient `C(n, k)`. We pin this
identification and the four core Hopf-algebra identities of the
ladder sector:

* `ckLadderCoeff_zero_zero`        — counit on the unit:
                                     `Δ-coeff at (0,0) = 1`.
* `ckLadderCoeff_left_unit`        — left projection of the
                                     counit: `Δ-coeff at (n,0) = 1`.
* `ckLadderCoeff_primitive`        — primitive sector:
                                     `Δ(x) = x⊗1 + 1⊗x`,
                                     i.e. `(1,0)` and `(1,1)` both
                                     have coefficient 1.
* `ckLadderCoeff_coassociativity`  — Pascal's rule realised as
                                     coassociativity of the
                                     Connes–Kreimer coproduct on
                                     ladder graphs.

## Stages NOT discharged here (require new infrastructure)

* The full graph-valued Hopf algebra `H_FG` on rooted Feynman
  graphs — needs an `Inductive` type for graphs with subgraph
  contractions and a free-algebra construction.
* The antipode `S : H_FG → H_FG` and its recursive expression in
  terms of forest formulas.
* The Birkhoff decomposition of dimensionally-regularised
  characters realising BPHZ renormalisation.
* The connection to the rooted-tree Hopf algebra `H_R` of
  Connes–Kreimer–Foissy (would require an `RootedTree` inductive
  type with `B+` grafting).

These are queued for Phase 2/3 once the ladder identification is
locked in.

## Phase status

Phase-1 — honest algebraic identities, machine-checked, kernel-only
`[propext, Classical.choice, Quot.sound]` axioms.
-/

set_option autoImplicit false

namespace CATEPTMain.Integration.ConnesKreimerLadder

/-- Connes–Kreimer ladder coefficient: the coefficient of the
    `(k, n−k)`-component of the coproduct `Δ(xⁿ)` in the ladder
    sub-Hopf-algebra of `H_FG`, identified with the binomial
    coefficient `C(n, k)` via the polynomial-Hopf-algebra
    isomorphism `ℝ⟨x⟩_ladder ≅ ℝ[x]`. -/
def ckLadderCoeff (n k : ℕ) : ℕ := n.choose k

/-- **Counit on the unit** of the ladder Hopf algebra:
    the `(0, 0)`-component of `Δ(x⁰) = 1 ⊗ 1` has coefficient 1. -/
theorem ckLadderCoeff_zero_zero :
    ckLadderCoeff 0 0 = 1 := by
  simp [ckLadderCoeff]

/-- **Left-projection unit law** of the Connes–Kreimer ladder
    coproduct: the `(n, 0)`-component of `Δ(xⁿ)` always has
    coefficient 1, expressing that the right tensor factor is the
    Hopf-algebra unit. -/
theorem ckLadderCoeff_left_unit (n : ℕ) :
    ckLadderCoeff n 0 = 1 := by
  simp [ckLadderCoeff]

/-- **Primitive sector** of the Connes–Kreimer ladder Hopf algebra:
    `Δ(x) = x ⊗ 1 + 1 ⊗ x`, so the coproduct coefficients at the
    `(1, 0)` and `(1, 1)` components both equal 1. -/
theorem ckLadderCoeff_primitive :
    ckLadderCoeff 1 0 = 1 ∧ ckLadderCoeff 1 1 = 1 := by
  refine ⟨?_, ?_⟩ <;> simp [ckLadderCoeff]

/-- **Coassociativity** of the Connes–Kreimer ladder coproduct,
    realised as Pascal's rule on binomial coefficients:

      `C(n+1, k+1)  =  C(n, k) + C(n, k+1)`.

    This is the algebraic content of the diagram

      `(Δ ⊗ id) ∘ Δ  =  (id ⊗ Δ) ∘ Δ`

    on the ladder generator `xⁿ⁺¹`, identifying the splitting of
    a depth-`(n+1)` divergent subgraph chain at depth `k+1` with
    the sum of its two intermediate factorisations. -/
theorem ckLadderCoeff_coassociativity (n k : ℕ) :
    ckLadderCoeff (n + 1) (k + 1)
      = ckLadderCoeff n k + ckLadderCoeff n (k + 1) := by
  simp [ckLadderCoeff, Nat.choose_succ_succ]

end CATEPTMain.Integration.ConnesKreimerLadder
