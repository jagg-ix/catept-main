

### Optional Material Backends (post v10.0-RC) ###
.PHONY: material_backend_pymatgen material_backend_help

material_backend_help:
	@echo "Optional backends (not required for paper reproduction):"
	@echo "  make material_backend_pymatgen   # structure summary + exports (requires pymatgen)"

material_backend_pymatgen:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO
	@python scripts/materials/backends/pymatgen_structure_summary.py \
	  --in data/materials/abinitio/structure.cif \
	  --out PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO


### Optional Optical-Constants -> Epsilon -> MEEP bridge ###
.PHONY: material_backend_nk_to_eps material_backend_meep_export

material_backend_nk_to_eps:
	@echo "Converting n,k table -> epsilon table..."
	@python scripts/materials/backends/optical_constants_from_nk.py \
	  --in data/materials/abinitio/nk_table.csv \
	  --out data/materials/abinitio/eps_from_nk.csv

material_backend_meep_export:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/MEEP
	@echo "Exporting MEEP stub from epsilon table..."
	@python scripts/materials/backends/meep_material_from_eps_table.py \
	  --in data/materials/abinitio/eps_from_nk.csv \
	  --out PAPER_TABLES/ADVANCED/MATERIALS/MEEP/meep_material_stub.py \
	  --material-name ITO_from_table


.PHONY: material_backend_meep_validate
material_backend_meep_validate:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/MEEP/VALIDATION
	@python scripts/materials/backends/meep_validate_eps.py \
	  --material-stub PAPER_TABLES/ADVANCED/MATERIALS/MEEP/meep_material_stub.py \
	  --out PAPER_TABLES/ADVANCED/MATERIALS/MEEP/VALIDATION


.PHONY: material_backend_fit_drude material_backend_meep_drude_template

material_backend_fit_drude:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/POLES/DRUDE
	@python scripts/materials/backends/fit_drude_poles.py \
	  --in data/materials/abinitio/eps_from_nk.csv \
	  --outdir PAPER_TABLES/ADVANCED/MATERIALS/POLES/DRUDE

material_backend_meep_drude_template:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/MEEP
	@python scripts/materials/backends/meep_medium_from_drude.py \
	  --in PAPER_TABLES/ADVANCED/MATERIALS/POLES/DRUDE/best_fit.json \
	  --out PAPER_TABLES/ADVANCED/MATERIALS/MEEP/meep_medium_drude.py


.PHONY: material_backend_meep_tr material_backend_meep_full

# Compute T/R/A spectra for a 1D slab using Drude-fit parameters (requires meep)
material_backend_meep_tr:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/MEEP/TR
	@python scripts/materials/backends/meep_slab_tr_from_drude.py \
	  --fit-json PAPER_TABLES/ADVANCED/MATERIALS/POLES/DRUDE/best_fit.json \
	  --outdir PAPER_TABLES/ADVANCED/MATERIALS/MEEP/TR

# Convenience: nk -> eps -> fit drude -> export template -> compute T/R/A
material_backend_meep_full:
	@$(MAKE) material_backend_nk_to_eps
	@$(MAKE) material_backend_fit_drude
	@$(MAKE) material_backend_meep_drude_template
	@$(MAKE) material_backend_meep_tr


### Optional Ab-initio (PySCF) bridge ###
.PHONY: material_backend_pyscf_cell material_backend_pyscf_scf material_backend_pyscf_eps

material_backend_pyscf_cell:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF
	@python scripts/materials/backends/pyscf_build_cell_from_cif.py \
	  --in data/materials/abinitio/structure.cif \
	  --out PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF

material_backend_pyscf_scf:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/SCF
	@python scripts/materials/backends/pyscf_run_scf.py \
	  --cell PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/pyscf_cell_params.json \
	  --out PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/SCF

material_backend_pyscf_eps:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/EPS
	@python scripts/materials/backends/pyscf_eps_tddft.py \
	  --cell PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/pyscf_cell_params.json \
	  --out PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/EPS


### Deepen loop helpers (v10.8) ###
.PHONY: material_backend_supercell_2x2x2 material_backend_pyscf_eps0 material_backend_compare_eps

material_backend_supercell_2x2x2:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO
	@python scripts/materials/backends/pymatgen_make_supercell.py \
	  --in data/materials/abinitio/structure.cif \
	  --out data/materials/abinitio/supercell_2x2x2.cif \
	  --scale 2,2,2 \
	  --prov PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/supercell_provenance.json

material_backend_pyscf_eps0:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/STATIC
	@python scripts/materials/backends/pyscf_static_eps_finite_field.py \
	  --cell PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/pyscf_cell_params.json \
	  --out PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/STATIC

# Compare measured vs ab-initio epsilon tables over the experiment band
material_backend_compare_eps:
	@mkdir -p PAPER_TABLES/ADVANCED/MATERIALS/REPORTS/EPS_COMPARE
	@python scripts/materials/backends/compare_eps_tables.py \
	  --a data/materials/abinitio/eps_from_nk.csv \
	  --b PAPER_TABLES/ADVANCED/MATERIALS/ABINITIO/PYSCF/EPS/eps_abinitio.csv \
	  --outdir PAPER_TABLES/ADVANCED/MATERIALS/REPORTS/EPS_COMPARE \
	  --fmin-thz 150 --fmax-thz 350
