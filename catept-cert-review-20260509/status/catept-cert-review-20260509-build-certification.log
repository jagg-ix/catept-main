    have step3 :
      (fun t : ℝ => c₀ * (t * (2 * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2)))) = fun t =>
        c₀ * ((2 * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2)) * t) :=
      by ext; ring
    rw [step3, intervalIntegral.integral_const_mul, intervalIntegral.integral_const_mul, integral_id]
    ring
  have hii :
    IntervalIntegrable (fun t : ℝ => c₀ * (t * (2 * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2)))) MeasureTheory.volume 0 1 :=
    (continuous_const.mul (continuous_id.mul continuous_const)).intervalIntegrable 0 1
  have hic : IntervalIntegrable (fun (_ : ℝ) => b 0 * v 0 + b 1 * v 1 + b 2 * v 2) MeasureTheory.volume 0 1 :=
    intervalIntegrable_const
  rw [show
      (fun t : ℝ => b 0 * v 0 + b 1 * v 1 + b 2 * v 2 + c₀ * (t * (2 * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2)))) = fun t =>
        (fun _ => b 0 * v 0 + b 1 * v 1 + b 2 * v 2) t +
