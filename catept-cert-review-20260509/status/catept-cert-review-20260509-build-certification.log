    (b 0 * v 0 + b 1 * v 1 + b 2 * v 2) + c₀ * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2) :=
  by
  have hA : ∫ (_ : ℝ) in (0 : ℝ)..1, (b 0 * v 0 + b 1 * v 1 + b 2 * v 2) = b 0 * v 0 + b 1 * v 1 + b 2 * v 2 := by
    rw [intervalIntegral.integral_const]; simp
  have hB :
    ∫ t in (0 : ℝ)..1, c₀ * (t * (2 * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2))) =
      c₀ * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2) :=
    by
    have step1 :
      (fun t : ℝ => t * (2 * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2))) = fun t =>
        (2 * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2)) * t :=
      by ext; ring
    have step2 : ∫ t in (0 : ℝ)..1, (2 * (v 0 * v 0 + v 1 * v 1 + v 2 * v 2)) * t = v 0 * v 0 + v 1 * v 1 + v 2 * v 2 :=
