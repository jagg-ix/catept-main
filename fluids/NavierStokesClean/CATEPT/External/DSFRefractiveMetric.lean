import Mathlib.Data.Matrix.Basic
import Mathlib.LinearAlgebra.Matrix.Notation
import Mathlib.Data.Real.Sqrt

/-!
# DSF Holographic Refractive Metric

Migrates the effective refractive index and spatial metric derivations
from legacy `mie_qcf_dsf.lean`.

Models the spatial metric structure $g_{ij}$ as an effective isotropic
refractive index:
  $n_{\text{dyn}}^2(F) = \lambda_A \cdot (\Delta x)^2 + \lambda_B$
  $g_{ij} = n_{\text{dyn}}^2 \cdot \delta_{ij}$
-/

set_option autoImplicit false

namespace NavierStokesClean.CATEPT.External.DSFRefractiveMetric

/-- The state of the dynamic field defining the refractive metric. -/
structure FieldState where
  Δx : ℝ  -- Spatial resolution/grid scale
  /-- Entropy-dependent field coupling A -/
  lambdaA : ℝ
  /-- Entropy-dependent field coupling B (background) -/
  lambdaB : ℝ

/-- Computes the dynamical refractive index squared.
    Maps field scales to an effective fluid/optical density. -/
noncomputable def n_squared_dyn (fs : FieldState) : ℝ :=
  fs.lambdaA * fs.Δx^2 + fs.lambdaB

/-- Final observable refractive index $n$ -/
noncomputable def measured_n (fs : FieldState) : ℝ :=
  Real.sqrt (n_squared_dyn fs)

/-- Effective isotropic spatial metric $g_{ij}$ generated by the refractive field.
    Used to close the spatial variation (1/2-derivative gap) by modulating spatial distance. -/
noncomputable def g_ij (fs : FieldState) : Matrix (Fin 3) (Fin 3) ℝ :=
  let n2 := n_squared_dyn fs
  Matrix.diagonal ![n2, n2, n2]

end NavierStokesClean.CATEPT.External.DSFRefractiveMetric
