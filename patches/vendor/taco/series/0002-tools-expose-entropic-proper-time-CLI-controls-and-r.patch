From ae6b5c33e680d074bf85603f3b265f72a94f854f Mon Sep 17 00:00:00 2001
From: "Jorge A. Garcia" <jag@mbeddix.com>
Date: Fri, 6 Mar 2026 13:08:19 -0600
Subject: [PATCH 2/2] tools: expose entropic proper-time CLI controls and
 reporting

---
 tools/taco.cpp | 130 +++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 130 insertions(+)

diff --git a/tools/taco.cpp b/tools/taco.cpp
index 30558c83..5f227881 100644
--- a/tools/taco.cpp
+++ b/tools/taco.cpp
@@ -146,6 +146,30 @@ static void printUsageInfo() {
             "Time compilation, assembly and <repeat> times computation "
             "(defaults to 1).");
   cout << endl;
+  printFlag("entropic-enable",
+            "Enable entropic proper-time tracking for the result tensor.");
+  cout << endl;
+  printFlag("entropic-lambda=<value>",
+            "Set external entropic rate lambda (>= 0).");
+  cout << endl;
+  printFlag("entropic-hbar=<value>",
+            "Set reduced Planck constant scale used by entropic tracking (> 0).");
+  cout << endl;
+  printFlag("entropic-dt=<value>",
+            "Set integration timestep used for entropic tracking (> 0).");
+  cout << endl;
+  printFlag("entropic-tau0=<value>",
+            "Set initial entropic proper time tau_ent(0) (>= 0).");
+  cout << endl;
+  printFlag("entropic-entropy-scale=<value>",
+            "Set additional entropy production scaling from kernel work proxy (>= 0).");
+  cout << endl;
+  printFlag("entropic-include-assemble",
+            "Include assemble stage contributions in entropic state updates.");
+  cout << endl;
+  printFlag("entropic-print",
+            "Print entropic state (tau_ent, delta_s_i, lambda_eff, steps) after execution.");
+  cout << endl;
   printFlag("write-time=<filename>",
             "Write computation times in csv format to <filename> "
             "as compileTime,assembleTime,mean,stdev,median.");
@@ -672,6 +696,9 @@ int main(int argc, char* argv[]) {
   bool verify              = false;
   bool time                = false;
   bool writeTime           = false;
+  bool entropicEnable      = false;
+  bool entropicPrint       = false;
+  bool entropicIncludeAssemble = false;
 
   bool color               = true;
   bool readKernels         = false;
@@ -683,6 +710,11 @@ int main(int argc, char* argv[]) {
   int chunkSize = 0;
   int nthreads = 0;
   string prefix = "";
+  double entropicLambdaRate = 0.0;
+  double entropicHbar = 1.0;
+  double entropicDt = 1.0;
+  double entropicTau0 = 0.0;
+  double entropicEntropyScale = 0.0;
 
   taco::util::TimeResults compileTime;
   taco::util::TimeResults assembleTime;
@@ -961,6 +993,50 @@ int main(int argc, char* argv[]) {
         }
       }
     }
+    else if ("-entropic-enable" == argName) {
+      entropicEnable = true;
+    }
+    else if ("-entropic-print" == argName) {
+      entropicPrint = true;
+    }
+    else if ("-entropic-include-assemble" == argName) {
+      entropicIncludeAssemble = true;
+    }
+    else if ("-entropic-lambda" == argName) {
+      try {
+        entropicLambdaRate = stod(argValue);
+      } catch (...) {
+        return reportError("Incorrect -entropic-lambda usage", 3);
+      }
+    }
+    else if ("-entropic-hbar" == argName) {
+      try {
+        entropicHbar = stod(argValue);
+      } catch (...) {
+        return reportError("Incorrect -entropic-hbar usage", 3);
+      }
+    }
+    else if ("-entropic-dt" == argName) {
+      try {
+        entropicDt = stod(argValue);
+      } catch (...) {
+        return reportError("Incorrect -entropic-dt usage", 3);
+      }
+    }
+    else if ("-entropic-tau0" == argName) {
+      try {
+        entropicTau0 = stod(argValue);
+      } catch (...) {
+        return reportError("Incorrect -entropic-tau0 usage", 3);
+      }
+    }
+    else if ("-entropic-entropy-scale" == argName) {
+      try {
+        entropicEntropyScale = stod(argValue);
+      } catch (...) {
+        return reportError("Incorrect -entropic-entropy-scale usage", 3);
+      }
+    }
     else if ("-write-time" == argName) {
       writeTimeFilename = argValue;
       writeTime = true;
@@ -1039,6 +1115,28 @@ int main(int argc, char* argv[]) {
     }
   }
 
+  if (entropicLambdaRate > 0.0 || entropicTau0 > 0.0 ||
+      entropicEntropyScale > 0.0 || entropicIncludeAssemble) {
+    entropicEnable = true;
+  }
+  if (entropicEnable) {
+    if (entropicLambdaRate < 0.0) {
+      return reportError("entropic lambda must be >= 0", 3);
+    }
+    if (entropicHbar <= 0.0) {
+      return reportError("entropic hbar must be > 0", 3);
+    }
+    if (entropicDt <= 0.0) {
+      return reportError("entropic dt must be > 0", 3);
+    }
+    if (entropicTau0 < 0.0) {
+      return reportError("entropic tau0 must be >= 0", 3);
+    }
+    if (entropicEntropyScale < 0.0) {
+      return reportError("entropic entropy scale must be >= 0", 3);
+    }
+  }
+
   // Print compute is the default if nothing else was asked for
   if (!printAssemble && !printEvaluate && !printIterationGraph &&
       !writeCompute && !writeAssemble && !writeKernels && !readKernels &&
@@ -1119,6 +1217,17 @@ int main(int argc, char* argv[]) {
   } catch (parser::ParseError& e) {
     return reportError(e.getMessage(), 6);
   }
+  if (entropicEnable) {
+    TensorBase::EntropicContext entropicContext;
+    entropicContext.enabled = true;
+    entropicContext.includeAssembleStage = entropicIncludeAssemble;
+    entropicContext.lambdaRate = entropicLambdaRate;
+    entropicContext.hbar = entropicHbar;
+    entropicContext.dt = entropicDt;
+    entropicContext.entropyProductionScale = entropicEntropyScale;
+    tensor.setEntropicContext(entropicContext);
+    tensor.resetEntropicState(entropicTau0);
+  }
 
   // Generate tensors
   for (auto& fills : tensorsFill) {
@@ -1229,6 +1338,17 @@ int main(int argc, char* argv[]) {
       } catch (parser::ParseError& e) {
         return reportError(e.getMessage(), 6);
       }
+      if (entropicEnable) {
+        TensorBase::EntropicContext entropicContext;
+        entropicContext.enabled = true;
+        entropicContext.includeAssembleStage = entropicIncludeAssemble;
+        entropicContext.lambdaRate = entropicLambdaRate;
+        entropicContext.hbar = entropicHbar;
+        entropicContext.dt = entropicDt;
+        entropicContext.entropyProductionScale = entropicEntropyScale;
+        customTensor.setEntropicContext(entropicContext);
+        customTensor.resetEntropicState(entropicTau0);
+      }
       customTensor.compileSource(kernelSource);
 
       if (time) {
@@ -1501,5 +1621,15 @@ int main(int argc, char* argv[]) {
     }
   }
 
+  if (entropicEnable && entropicPrint) {
+    auto entropic = tensor.getEntropicState();
+    cout << "entropic-state:"
+         << " tau_ent=" << entropic.tauEnt
+         << " delta_s_i=" << entropic.deltaSI
+         << " lambda_eff=" << entropic.lambdaEff
+         << " steps=" << entropic.steps
+         << endl;
+  }
+
   return 0;
 }
-- 
2.48.1

