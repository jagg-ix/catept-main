From b0ffe6bf758b514c2ab61e339646a2dc6275c458 Mon Sep 17 00:00:00 2001
From: "Jorge A. Garcia" <jag@mbeddix.com>
Date: Fri, 6 Mar 2026 13:08:11 -0600
Subject: [PATCH 1/2] tensor: add first-class entropic proper-time
 context/state

---
 include/taco/tensor.h | 40 ++++++++++++++++++++++++++
 src/tensor.cpp        | 66 +++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 106 insertions(+)

diff --git a/include/taco/tensor.h b/include/taco/tensor.h
index dbc1cf33..852944d7 100644
--- a/include/taco/tensor.h
+++ b/include/taco/tensor.h
@@ -44,6 +44,25 @@ struct ScalarAccess;
 /// `TensorBase`.
 class TensorBase {
 public:
+  /// Entropic proper-time configuration used to advance CAT/EPT state during
+  /// tensor execution stages.
+  struct EntropicContext {
+    bool enabled = false;
+    bool includeAssembleStage = false;
+    double lambdaRate = 0.0;
+    double hbar = 1.0;
+    double dt = 1.0;
+    double entropyProductionScale = 0.0;
+  };
+
+  /// Runtime entropic state accumulated while the tensor executes.
+  struct EntropicState {
+    double tauEnt = 0.0;
+    double deltaSI = 0.0;
+    double lambdaEff = 0.0;
+    int steps = 0;
+  };
+
   /* --- Constructor Methods --- */
 
   /// Create a scalar
@@ -433,6 +452,23 @@ public:
   /// Compile, assemble and compute as needed.
   void evaluate();
 
+  /// Set the entropic proper-time execution context.
+  void setEntropicContext(const EntropicContext& context);
+
+  /// Convenience overload for setting the entropic proper-time execution context.
+  void setEntropicContext(bool enabled, double lambdaRate, double hbar,
+                          double dt, double entropyProductionScale = 0.0,
+                          bool includeAssembleStage = false);
+
+  /// Get the currently configured entropic proper-time context.
+  EntropicContext getEntropicContext() const;
+
+  /// Get the current entropic proper-time runtime state.
+  EntropicState getEntropicState() const;
+
+  /// Reset the entropic proper-time runtime state.
+  void resetEntropicState(double tauEnt0 = 0.0);
+
   /// True if the Tensor needs to be packed.
   bool needsPack();
 
@@ -522,6 +558,8 @@ private:
 
   void syncValues();
 
+  void advanceEntropicState(bool fromAssembleStage);
+
   template<typename CType>
   iterator_wrapper<int,CType> iteratorPacked();
   
@@ -915,6 +953,8 @@ struct TensorBase::Content {
   bool               needsCompile;
   bool               needsAssemble;
   bool               needsCompute;
+  EntropicContext    entropicContext;
+  EntropicState      entropicState;
   std::vector<std::weak_ptr<TensorBase::Content>> dependentTensors;
   unsigned int       uniqueId;
 
diff --git a/src/tensor.cpp b/src/tensor.cpp
index 257c396c..aaf83eb6 100644
--- a/src/tensor.cpp
+++ b/src/tensor.cpp
@@ -6,6 +6,7 @@
 #include <sstream>
 #include <cstdlib>
 #include <climits>
+#include <cmath>
 #include <vector>
 #include <utility>
 #include <mutex>
@@ -124,6 +125,7 @@ TensorBase::TensorBase(string name, Datatype ctype, vector<int> dimensions,
   taco_uassert(ctype == fill.getDataType()) << "Fill value must be of the same type as the tensor.";
 
   content->allocSize = 1 << 20;
+  content->valuesSize = 0;
 
   vector<ModeIndex> modeIndices(format.getOrder());
   // Initialize dense storage modes
@@ -144,6 +146,8 @@ TensorBase::TensorBase(string name, Datatype ctype, vector<int> dimensions,
   content->needsCompile = false;
   content->needsAssemble = false;
   content->needsCompute = false;
+  content->entropicContext = TensorBase::EntropicContext();
+  content->entropicState = TensorBase::EntropicState();
 
   content->coordinateBuffer = shared_ptr<vector<char>>(new vector<char>);
   content->coordinateBufferUsed = 0;
@@ -823,6 +827,7 @@ void TensorBase::assemble() {
     setNeedsAssemble(false);
     taco_tensor_t* tensorData = ((taco_tensor_t*)arguments[0]);
     content->valuesSize = unpackTensorData(*tensorData, *this);
+    advanceEntropicState(true);
   }
 }
 
@@ -847,6 +852,7 @@ void TensorBase::compute() {
     taco_tensor_t* tensorData = ((taco_tensor_t*)arguments[0]);
     content->valuesSize = unpackTensorData(*tensorData, *this);
   }
+  advanceEntropicState(false);
 }
 
 void TensorBase::evaluate() {
@@ -857,6 +863,66 @@ void TensorBase::evaluate() {
   this->compute();
 }
 
+void TensorBase::setEntropicContext(const EntropicContext& context) {
+  taco_uassert(context.hbar > 0.0) << "entropic context hbar must be > 0";
+  taco_uassert(context.dt > 0.0) << "entropic context dt must be > 0";
+  taco_uassert(context.lambdaRate >= 0.0)
+      << "entropic context lambdaRate must be >= 0";
+  taco_uassert(context.entropyProductionScale >= 0.0)
+      << "entropic context entropyProductionScale must be >= 0";
+  content->entropicContext = context;
+}
+
+void TensorBase::setEntropicContext(bool enabled, double lambdaRate, double hbar,
+                                    double dt, double entropyProductionScale,
+                                    bool includeAssembleStage) {
+  EntropicContext ctx;
+  ctx.enabled = enabled;
+  ctx.includeAssembleStage = includeAssembleStage;
+  ctx.lambdaRate = lambdaRate;
+  ctx.hbar = hbar;
+  ctx.dt = dt;
+  ctx.entropyProductionScale = entropyProductionScale;
+  setEntropicContext(ctx);
+}
+
+TensorBase::EntropicContext TensorBase::getEntropicContext() const {
+  return content->entropicContext;
+}
+
+TensorBase::EntropicState TensorBase::getEntropicState() const {
+  return content->entropicState;
+}
+
+void TensorBase::resetEntropicState(double tauEnt0) {
+  taco_uassert(tauEnt0 >= 0.0) << "entropic state tauEnt0 must be >= 0";
+  content->entropicState = TensorBase::EntropicState();
+  content->entropicState.tauEnt = tauEnt0;
+}
+
+void TensorBase::advanceEntropicState(bool fromAssembleStage) {
+  const EntropicContext& ctx = content->entropicContext;
+  if (!ctx.enabled) {
+    return;
+  }
+  if (fromAssembleStage && !ctx.includeAssembleStage) {
+    return;
+  }
+  const double workProxy = static_cast<double>(
+      content->valuesSize > 0 ? content->valuesSize
+                              : content->storage.getValues().getSize());
+  double deltaSI = (ctx.hbar * ctx.lambdaRate +
+                    ctx.entropyProductionScale * workProxy) * ctx.dt;
+  if (!std::isfinite(deltaSI) || deltaSI < 0.0) {
+    deltaSI = 0.0;
+  }
+  content->entropicState.deltaSI = deltaSI;
+  content->entropicState.lambdaEff =
+      (ctx.hbar > 0.0 && ctx.dt > 0.0) ? deltaSI / (ctx.hbar * ctx.dt) : 0.0;
+  content->entropicState.tauEnt += deltaSI / ctx.hbar;
+  content->entropicState.steps += 1;
+}
+
 void TensorBase::operator=(const IndexExpr& expr) {
   taco_uassert(getOrder() == 0)
       << "Must use index variable on the left-hand-side when assigning an "
